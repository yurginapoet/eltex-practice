root@eltex-practice2-pg2-v4:~# nano uid.sh
root@eltex-practice2-pg2-v4:~# cat uid.sh 
#!/bin/bash

while IFS: read -r uname x uid gid comm home shell; do
	if [ "$shell" = "/usr/sbin/nologin" ]; then
		groups=$(awk -F: -v u="$uname" '$4 ~ u {print $1}' /etc/group | paste -sd ", " -)
		echo "$uid, $uname, $groups"
	fi
done < /etc/passwd | sort -n -r
